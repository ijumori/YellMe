rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isString(field) {
      return field is string && field.size() > 0;
    }

    // ユーザープロフィール（ドキュメント ID = Firebase Auth UID）
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      // 日次記録（本人のみ）
      match /dailyEntries/{calendarDay} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isString(request.resource.data.id)
          && request.resource.data.id == calendarDay
          && request.resource.data.selectedWinIds is list
          && request.resource.data.submissionCount is int
          && request.resource.data.submissionCount >= 0;
        allow update: if isOwner(userId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.submissionCount is int
          && request.resource.data.submissionCount >= resource.data.submissionCount;
        allow delete: if false;
      }
    }

    // SNS用途（投稿・リアクション・フォロー）は無効化
    match /posts/{postId} {
      allow read, write: if false;
    }
    match /follows/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
