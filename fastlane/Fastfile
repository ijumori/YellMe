# frozen_string_literal: true

default_platform(:ios)

REPO_ROOT = File.expand_path("..", __dir__)

platform :ios do
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_API_KEY_ID"),
      issuer_id: ENV.fetch("ASC_API_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("ASC_API_KEY_PATH"), REPO_ROOT),
      duration: 1200,
      in_house: false
    )
  end

  desc "スクショ + アプリプレビュー動画をアップロード（メタデータは変更しない）。fastlane 2.234+ 必須。"
  lane :asc_screenshots do
    screenshots_path = File.join(REPO_ROOT, "AppStoreMetadata", "deliver", "screenshots")
    UI.user_error!("スクショ先が見つかりません: #{screenshots_path}") unless Dir.exist?(screenshots_path)

    preview_root = File.join(REPO_ROOT, "AppStoreMetadata", "deliver", "app-previews")
    preview_ja = File.join(preview_root, "ja")
    has_previews = Dir.exist?(preview_ja) && !Dir.glob(File.join(preview_ja, "*.mp4")).empty?

    deliver_opts = {
      api_key: asc_api_key,
      app_identifier: "com.takahiro.yellme",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: screenshots_path,
      overwrite_screenshots: false,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false
    }
    if has_previews
      deliver_opts[:app_previews_path] = preview_root
      deliver_opts[:overwrite_preview_videos] = false
      UI.message("App Preview をアップロードします: #{preview_root}")
    else
      UI.important("App Preview なし（#{preview_ja} に .mp4 が無い）→ スクリーンショットのみ")
    end

    deliver(deliver_opts)
  end

  desc "Apple ID 認証でスクショ + プレビュー + メタデータを一括アップロード"
  lane :upload_all do
    screenshots_path = File.join(REPO_ROOT, "AppStoreMetadata", "deliver", "screenshots")
    UI.user_error!("スクショ先が見つかりません: #{screenshots_path}") unless Dir.exist?(screenshots_path)

    metadata_path = File.join(REPO_ROOT, "fastlane", "metadata")
    preview_root = File.join(REPO_ROOT, "AppStoreMetadata", "deliver", "app-previews")
    preview_ja = File.join(preview_root, "ja")
    has_previews = Dir.exist?(preview_ja) && !Dir.glob(File.join(preview_ja, "*.mp4")).empty?

    deliver_opts = {
      app_identifier: "com.takahiro.yellme",
      skip_binary_upload: true,
      skip_metadata: false,
      metadata_path: metadata_path,
      skip_screenshots: false,
      screenshots_path: screenshots_path,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false
    }
    if has_previews
      deliver_opts[:app_previews_path] = preview_root
      deliver_opts[:overwrite_preview_videos] = true
      UI.message("App Preview をアップロードします: #{preview_root}")
    end

    deliver(deliver_opts)
  end

  desc "App Store Connect の最新ビルド番号を取得して +1 し、project.yml を更新 → xcodegen generate"
  lane :bump_build do
    api_key = asc_api_key
    live = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.takahiro.yellme"
    )
    new_build = live + 1
    UI.message("ASC 最新ビルド番号: #{live} → 新ビルド番号: #{new_build}")

    project_yml = File.join(REPO_ROOT, "project.yml")
    content = File.read(project_yml)
    content = content.gsub(/CURRENT_PROJECT_VERSION:\s*\d+/, "CURRENT_PROJECT_VERSION: #{new_build}")
    content = content.gsub(/CFBundleVersion:\s*"\d+"/, "CFBundleVersion: \"#{new_build}\"")
    File.write(project_yml, content)
    UI.message("project.yml を更新しました (build #{new_build})")

    Dir.chdir(REPO_ROOT) do
      sh("xcodegen", "generate")
    end
    UI.success("ビルド番号を #{new_build} に更新しました")
    new_build
  end

  desc "Archive 済み IPA を App Store Connect にアップロード（API キー優先、なければ Apple ID + アプリ用パスワード）"
  lane :upload_build do
    bump_build

    ipa = ENV["IPA_PATH"] || File.join(REPO_ROOT, "build", "AppStoreExport", "YellMe.ipa")
    UI.user_error!("IPA がありません。先に ./scripts/archive-export-appstore.sh を実行: #{ipa}") unless File.exist?(ipa)

    upload_opts = {
      ipa: ipa,
      app_identifier: "com.takahiro.yellme",
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submit_for_review: false
    }
    if ENV["ASC_API_KEY_ID"] && ENV["ASC_API_ISSUER_ID"] && ENV["ASC_API_KEY_PATH"]
      upload_opts[:api_key] = asc_api_key
    end

    upload_to_app_store(upload_opts)
    UI.success("ビルドをアップロードしました。TestFlight で処理完了後、審査提出できます。")
  end

  desc "メタデータを反映し審査へ提出（ビルドは ASC で選択済みであること）"
  lane :submit_review do
    metadata_path = File.join(REPO_ROOT, "fastlane", "metadata")
    deliver(
      app_identifier: "com.takahiro.yellme",
      skip_binary_upload: true,
      skip_metadata: false,
      metadata_path: metadata_path,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: true,
      automatic_release: false
    )
  end
end
